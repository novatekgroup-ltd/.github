# Node.js / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.env
.venv

# Docker
docker-compose.override.yml
.env.local
.env.*.local

# OS metadata
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE / Editors
.vscode/
.idea/
*.iml

# Build artifacts (ignore contents, but keep directory structure via .gitkeep)
build/*
!build/.gitkeep
dist/
*.log
*.tmp

# Sensitive data
secrets/
*.key
*.pem
*.crt
*.pfx
config/local.json
config/local.*
!config/.gitkeep

# Test coverage
coverage/
*.cover
.nyc_output/

# Asset uploads (ignore user content, keep folder)
assets/uploads/*
!assets/.gitkeep
