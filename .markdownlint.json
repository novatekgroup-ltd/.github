{
  "default": true,
  "line-length": false,
  "no-inline-html": {
    "allowed_elements": ["img", "br", "p", "div", "sub", "table", "tr", "td", "th", "a"]
  },
  "no-duplicate-heading": false,
  "no-trailing-punctuation": false,
  "ul-indent": { "indent": 2 },
  "ol-prefix": { "style": "ordered" },
  "no-bare-urls": false
}
